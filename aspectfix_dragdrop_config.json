{
  "OutputFolder": "C:\\output_aspect_fixed",
  "RecursiveFolderDrop": true,
  "KeepFolderStructureWhenFolderAdded": false,
  "Extensions": [
    ".jpg",
    ".jpeg",
    ".png",
    ".webp",
    ".bmp"
  ],
  "Mode": "manual_scale",
  "XScale": 1.185185,
  "YScale": 1.0,
  "DefaultPreset": "720x480 → 16:9表示相当補正",
  "CanvasMode": "なし",
  "SaveCanvasAspectRatio": "16:9",
  "CanvasPadColor": "黒",
  "OutputFormat": "keep_original",
  "Suffix": "_aspectfix",
  "JpegQuality": 95,
  "WebpQuality": 95,
  "Interpolation": "lanczos",
  "Overwrite": false,
  "DeleteSource": false,
  "WindowGeometry": "1560x980"
}
